<Window x:Class="chess.windows.menu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Chess" Height="560" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        ResizeMode="CanResize"
        WindowState="Maximized">

    <Window.Resources>

        <!-- Colors -->
        <SolidColorBrush x:Key="GoldBrush"       Color="#C9A84C"/>
        <SolidColorBrush x:Key="GoldDimBrush"    Color="#8A6E2F"/>
        <SolidColorBrush x:Key="SurfaceBrush"    Color="#161616"/>
        <SolidColorBrush x:Key="CardBrush"        Color="#1C1C1C"/>
        <SolidColorBrush x:Key="CardHoverBrush"   Color="#232323"/>
        <SolidColorBrush x:Key="BorderBrush"      Color="#2E2E2E"/>
        <SolidColorBrush x:Key="TextPrimary"      Color="#F0EDE6"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#7A7672"/>

        <!-- Menu Button Style -->
        <Style x:Key="MenuCardStyle" TargetType="Button">
            <Setter Property="Background"         Value="#1C1C1C"/>
            <Setter Property="Foreground"         Value="#F0EDE6"/>
            <Setter Property="BorderBrush"        Value="#2E2E2E"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="Width"              Value="200"/>
            <Setter Property="Height"             Value="200"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background"   Value="#232323"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush"  Value="#C9A84C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background"  Value="#1A1A1A"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="#8A6E2F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Divider line -->
        <Style x:Key="GoldDivider" TargetType="Rectangle">
            <Setter Property="Height"  Value="1"/>
            <Setter Property="Fill"    Value="#2E2E2E"/>
            <Setter Property="Margin"  Value="0,0,0,0"/>
        </Style>

        <!-- Footer link button -->
        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#7A7672"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="Lbl"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground" Value="#C9A84C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Cards -->
            <RowDefinition Height="Auto"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,52,0,44">

            <!-- Chess piece decorators -->
            <TextBlock Text="♜  ♛  ♚  ♛  ♜"
                       FontSize="18"
                       Foreground="#2E2E2E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18"/>

            <!-- Title -->
            <TextBlock Text="CHESS"
                       FontSize="52"
                       FontWeight="Bold"
                       Foreground="#F0EDE6"
                       HorizontalAlignment="Center"
                       FontFamily="Georgia, 'Times New Roman', serif"/>

            <!-- Gold rule -->
            <Rectangle Height="1"
                       Width="120"
                       Margin="0,14,0,12">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent"  Offset="0"/>
                        <GradientStop Color="#C9A84C"      Offset="0.5"/>
                        <GradientStop Color="Transparent"  Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <TextBlock Text="choose your game"
                       FontSize="11"
                       Foreground="#5A5652"
                       HorizontalAlignment="Center"
                       FontFamily="Georgia, serif"/>
        </StackPanel>

        <!-- ══ CARDS ══ -->
        <UniformGrid Grid.Row="1"
                     Rows="1" Columns="4"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Margin="60,0,60,0">

            <!-- LOCAL -->
            <Button Style="{StaticResource MenuCardStyle}"
                    Margin="12,0"
                    Click="PlayLocal_Click">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="160">

                    <TextBlock Text="♟"
                               FontSize="44"
                               HorizontalAlignment="Center"
                               Foreground="#C9A84C"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="LOCAL"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#C9A84C"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Play Yourself"
                               FontSize="18"
                               Foreground="#F0EDE6"
                               HorizontalAlignment="Center"
                               FontFamily="Georgia, serif"
                               Margin="0,0,0,14"/>

                    <Rectangle Style="{StaticResource GoldDivider}"
                               Margin="24,0"/>

                    <TextBlock Text="Two players, one board"
                               FontSize="11"
                               Foreground="#5A5652"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Button>

            <!-- ONLINE -->
            <Button Style="{StaticResource MenuCardStyle}"
                    Margin="12,0"
                    Click="PlayOnline_Click">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="160">

                    <TextBlock Text="♞"
                               FontSize="44"
                               HorizontalAlignment="Center"
                               Foreground="#C9A84C"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="ONLINE"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#C9A84C"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Play Online"
                               FontSize="18"
                               Foreground="#F0EDE6"
                               HorizontalAlignment="Center"
                               FontFamily="Georgia, serif"
                               Margin="0,0,0,14"/>

                    <Rectangle Style="{StaticResource GoldDivider}"
                               Margin="24,0"/>

                    <TextBlock Text="Challenge players worldwide"
                               FontSize="11"
                               Foreground="#5A5652"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Button>

            <!-- AI -->
            <Button Style="{StaticResource MenuCardStyle}"
                    Margin="12,0"
                    Click="PlayAI_Click">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="160">

                    <TextBlock Text="♛"
                               FontSize="44"
                               HorizontalAlignment="Center"
                               Foreground="#C9A84C"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="AI"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#C9A84C"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Play vs AI"
                               FontSize="18"
                               Foreground="#F0EDE6"
                               HorizontalAlignment="Center"
                               FontFamily="Georgia, serif"
                               Margin="0,0,0,14"/>

                    <Rectangle Style="{StaticResource GoldDivider}"
                               Margin="24,0"/>

                    <TextBlock Text="Test your skills against the engine"
                               FontSize="11"
                               Foreground="#5A5652"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Button>
            <!-- REPLAY -->
            <Button Style="{StaticResource MenuCardStyle}"
                    Margin="12,0"
                    Click="PlayReplay_Click">
                <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="160">

                    <TextBlock Text="♻"
                   FontSize="44"
                   HorizontalAlignment="Center"
                   Foreground="#C9A84C"
                   Margin="0,0,0,16"/>

                    <TextBlock Text="REPLAY"
                   FontSize="11"
                   FontWeight="Bold"
                   Foreground="#C9A84C"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6"/>

                    <TextBlock Text="Watch Replay"
                   FontSize="18"
                   Foreground="#F0EDE6"
                   HorizontalAlignment="Center"
                   FontFamily="Georgia, serif"
                   Margin="0,0,0,14"/>

                    <Rectangle Style="{StaticResource GoldDivider}"
                   Margin="24,0"/>

                    <TextBlock Text="Replay a past game"
                   FontSize="11"
                   Foreground="#5A5652"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Margin="0,12,0,0"/>
                </StackPanel>
            </Button>
        </UniformGrid>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="#1E1E1E"
                Margin="0,24,0,0"
                Padding="40,16">
            <Grid>
                <TextBlock Text="v1.0"
                           Foreground="#333330"
                           FontSize="11"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Settings"  Style="{StaticResource LinkButtonStyle}" Margin="0,0,24,0" Click="Settings_Click"/>
                    <Button Content="About"     Style="{StaticResource LinkButtonStyle}" Click="About_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
